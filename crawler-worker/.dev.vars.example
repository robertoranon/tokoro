# Local development secrets for wrangler dev
# Copy this file to .dev.vars and fill in your actual values

# API Keys (comma-separated for multiple clients)
CRAWLER_API_KEYS=test-key-1,test-key-2

# Crawler Keypair (generate with: cd ../crawler && npm run crawl -- --generate-keypair)
CRAWLER_PRIVKEY=your_private_key_hex_here
CRAWLER_PUBKEY=your_public_key_hex_here

# LLM Provider Configuration
LLM_PROVIDER=openai
# or: anthropic, openrouter

# LLM API Key (depends on provider)
LLM_API_KEY=your_llm_api_key_here

# Optional: LLM Model Override
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_MODEL=google/gemini-2.0-flash-exp:free

# Optional: Jina AI Reader API Key (improves rate limits)
# Get a free API key at https://jina.ai/reader
# JINA_API_KEY=jina_key

# Telegram Bot (optional — only needed if using the bot)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# BOT_PRIVKEY=your_bot_ed25519_privkey_hex
# BOT_PUBKEY=your_bot_ed25519_pubkey_hex
# API_WORKER_URL=https://tokoro-worker.your-account.workers.dev
