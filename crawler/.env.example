# LLM Provider Configuration
LLM_PROVIDER=openrouter  # Options: openrouter, openai, anthropic, ollama

# API Keys (only needed for cloud providers)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# See https://openrouter.ai/models for available models

OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama Configuration (for local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Tokoro API
TOKORO_API_URL=https://tokoro-worker.YOUR_SUBDOMAIN.workers.dev
# Or for local testing:
# TOKORO_API_URL=http://localhost:8787

# Crawler Keypair (Ed25519)
CRAWLER_PRIVKEY=your_64_char_hex_private_key
CRAWLER_PUBKEY=your_64_char_hex_public_key

# Optional: Jina AI Reader API Key (improves rate limits)
# Get a free API key at https://jina.ai/reader
JINA_API_KEY=jina_key

# Browser engine for Playwright fetcher (default: chrome)
# Options: chrome (headless Chrome via Playwright) | obscura (faster, stealthy, auto-launched)
# BROWSER_ENGINE=chrome

# Optional: connect to a running Obscura instance instead of auto-launching one
# When set, BROWSER_ENGINE=obscura will connect here rather than spawning a new process
# OBSCURA_WS_ENDPOINT=ws://127.0.0.1:9222
